#version 450
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : enable

layout(local_size_x = 256) in;

layout(std430, binding = 0) readonly buffer Inter { float data[]; } bufInter;
layout(std430, binding = 1) writeonly buffer Output { float16_t data[]; } bufOut;

layout(push_constant) uniform Config {
    uint total_elements;
} config;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < config.total_elements) {
        float val = bufInter.data[idx];
        bufOut.data[idx] = float16_t(tanh(val));
    }
}
