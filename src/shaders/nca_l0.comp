#version 450

layout(local_size_x = 32, local_size_y = 1) in; 

layout(std430, binding = 0) readonly buffer InputA { float data[]; } bufS;
layout(std430, binding = 1) writeonly buffer OutputC { float data[]; } bufOut;
layout(std430, binding = 2) readonly buffer Weights { float kernel[]; } bufW;

layout(push_constant) uniform Config {
    uint width, height, channels;
    float dt;
    uint row_offset;
} config;

void main() {
    uint num_pixels = config.width * config.height;
    uint pixel_idx = gl_GlobalInvocationID.x; 
    uint channel_idx = gl_GlobalInvocationID.y;

    if (pixel_idx >= num_pixels || channel_idx >= config.channels) return;

    // FP32 標量計算：最穩定的 L0 測試邏輯
    float sum = 0.0;
    for (uint k = 0; k < config.channels; k++) {
        sum += bufW.kernel[channel_idx * config.channels + k] * bufS.data[pixel_idx * config.channels + k];
    }

    bufOut.data[pixel_idx * config.channels + channel_idx] = tanh(sum);
}
